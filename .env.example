# Token para autenticar el backend (endpoint /registrar)
MY_API_TOKEN=CAMBIA_ESTE_TOKEN

# Contraseña del login del dashboard (opcional).
# Si no se define, el dashboard usa MY_API_TOKEN como fallback.
DASHBOARD_PASSWORD=CAMBIA_ESTA_CONTRASEÑA

# Ruta opcional de la base SQLite.
# Recomendado: dejarlo como "finanzas.db" (por defecto) y ejecutar desde la carpeta del proyecto.
# DB_PATH=finanzas.db
